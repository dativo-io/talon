# Talon Infrastructure Configuration — OpenClaw Gateway (talon.config.yaml)
# Owner: DevOps / platform team
# Generated by: talon init --pack openclaw
#
# This config runs Talon as an OpenAI-compatible gateway in front of OpenClaw.
# OpenClaw sends every chat request to Talon; Talon resolves the presented key
# to the OpenClaw agent (agent.talon.yaml carries the identity, #266), scans
# for PII, enforces cost/model limits, forwards to OpenAI, and writes an audit
# record.
#
# Quick start:
#   1. Set your real OpenAI key:    talon secrets set openai-api-key "sk-..."
#   2. Mint the agent traffic key:  talon secrets set {{ .Name }}-talon-key "$(openssl rand -hex 24)"
#   3. Start the gateway:           talon serve --gateway
#   4. Point OpenClaw at:           http://localhost:8080/v1/proxy/openai
#      with API key set to the value you stored in {{ .Name }}-talon-key
#   5. Check audit trail:           talon audit list

llm:
  pricing_file: "pricing/models.yaml"

log_level: info
log_format: console

# Governed semantic cache (optional, off by default)
cache:
  enabled: false
  default_ttl: 3600
  similarity_threshold: 0.92
  max_entries_per_tenant: 10000

# Secrets encryption key: export TALON_SECRETS_KEY=<key> (openssl rand -hex 32)

gateway:
  enabled: true
  listen_prefix: "/v1/proxy"
  mode: "shadow"  # Start safe. Run 'talon enforce report' after 24h, then 'talon enforce enable'.

  providers:
    openai:
      enabled: true
      secret_name: "openai-api-key"
      base_url: "https://api.openai.com"
      allowed_models: ["gpt-4o", "gpt-4o-mini", "gpt-4-turbo"]

  # Traffic identity lives in agent.talon.yaml (agent.key.secret_name, #266);
  # this block is the organization baseline every agent inherits.
  organization_policy:
    defaults:
      pii_action: "warn"
      # warn = audit PII in evidence (recommended for LLM-generated content).
      # Escalate to "redact" or "block" for stricter environments.
      response_pii_action: "warn"
      daily_cost: 100.00
      monthly_cost: 2000.00
      # Tool governance: strip dangerous tools from LLM requests before the model sees them.
      # "filter" (default) removes forbidden tools; "block" rejects the entire request.
      tool_policy_action: "filter"
      # Attachment scanning: scans base64-encoded files (PDF, TXT, CSV, HTML)
      # in LLM API requests for PII and prompt injection.
      attachment_policy:
        action: "warn"            # block | strip | warn | allow
        injection_action: "warn"  # block | strip | warn
        max_file_size_mb: 10
    constraints:
      forbidden_tools:
        - "delete_*"
        - "admin_*"
        - "export_all_*"
        - "bulk_*"
        - "rm_*"
        - "drop_*"
    log_prompts: true
    log_responses: false

  rate_limits:
    global_requests_per_min: 300
    per_agent_requests_per_min: 60

  timeouts:
    connect_timeout: 10s
    request_timeout: 120s
    stream_idle_timeout: 60s
