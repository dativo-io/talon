{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": ".talon.yaml Configuration",
  "description": "Dativo Talon agent policy configuration v2.0. Canonical source: internal/policy/agent.talon.schema.json (embedded into the binary and used by `talon validate`); schemas/agent.talon.schema.json is a synced copy.",
  "type": "object",
  "required": ["agent", "policies"],
  "additionalProperties": true,
  "properties": {
    "agent": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9_-]+$"},
        "description": {"type": "string"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "model_tier": {"type": "integer", "minimum": 0, "maximum": 2},
        "tenant_id": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9_-]+$", "description": "Tenant this AI use case belongs to. One agent = one tenant; key → agent → tenant_id is the only tenant derivation. Omitted = \"default\"."},
        "enabled": {"type": "boolean", "description": "Operational on/off switch (#268). false denies NEW work for this agent (gateway requests, native runs, scheduled triggers) with an explicit reason; in-flight work finishes. Default: true. Toggle with `talon agents enable/disable <name>` — YAML stays the source of truth."},
        "key": {
          "type": "object",
          "description": "The agent's one active Talon traffic key, referenced by vault secret name. Policy files are committed to Git, so raw key material is impossible here by schema. Required for gateway-loaded agents.",
          "required": ["secret_name"],
          "additionalProperties": false,
          "properties": {
            "secret_name": {"type": "string", "minLength": 1}
          }
        },
        "accept_client_metadata": {"type": "boolean", "description": "Record client-asserted orchestration identity (session/subagent headers) in evidence for this agent's gateway traffic. Default true; recording only, never a policy input."}
      }
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "allowed_tools": {"type": "array", "items": {"type": "string"}},
        "allowed_data_sources": {"type": "array", "items": {"type": "string"}},
        "forbidden_patterns": {"type": "array", "items": {"type": "string"}},
        "destructive_patterns": {"type": "array", "items": {"type": "string"}},
        "forbidden_tools": {"type": "array", "items": {"type": "string"}, "description": "Tool NAMES denied for this agent's gateway traffic (unioned with the organization baseline and provider restrictions)."},
        "tool_policy_action": {"type": "string", "enum": ["filter", "block"], "description": "Gateway enforcement when a request declares disallowed tools: filter strips them, block rejects the request."}
      }
    },
    "triggers": {
      "type": "object",
      "properties": {
        "schedule": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["cron", "prompt"],
            "properties": {
              "cron": {"type": "string"},
              "prompt": {"type": "string"},
              "description": {"type": "string"}
            }
          }
        },
        "webhooks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "source", "prompt_template"],
            "properties": {
              "name": {"type": "string", "pattern": "^[a-z0-9-]+$"},
              "source": {"type": "string", "enum": ["generic", "github", "jira", "slack"]},
              "prompt_template": {"type": "string"},
              "require_approval": {"type": "boolean"}
            }
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "allowed": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {"type": "string"},
              "purpose": {"type": "string"}
            }
          }
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {"type": "string"}
            }
          }
        }
      }
    },
    "memory": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "mode": {"type": "string", "enum": ["active", "shadow", "disabled"]},
        "max_entries": {"type": "integer", "minimum": 1},
        "max_entry_size_kb": {"type": "integer", "minimum": 1},
        "max_prompt_tokens": {"type": "integer", "minimum": 0},
        "retention_days": {"type": "integer", "minimum": 1},
        "review_mode": {"type": "string", "enum": ["auto", "human-review", "read-only"]},
        "allowed_categories": {"type": "array", "items": {"type": "string"}},
        "forbidden_categories": {"type": "array", "items": {"type": "string"}},
        "prompt_categories": {"type": "array", "items": {"type": "string"}},
        "audit": {"type": "boolean"},
        "governance": {
          "type": "object",
          "properties": {
            "conflict_resolution": {"type": "string", "enum": ["auto", "flag_for_review", "reject"]},
            "conflict_similarity_threshold": {"type": "number", "minimum": 0, "maximum": 1},
            "trust_score_overrides": {"type": "boolean"},
            "dedup_window_minutes": {"type": "integer", "minimum": 0}
          }
        }
      }
    },
    "context": {
      "type": "object",
      "properties": {
        "shared_mounts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "classification"],
            "properties": {
              "name": {"type": "string"},
              "path": {"type": "string"},
              "description": {"type": "string"},
              "classification": {"type": "string", "enum": ["tier_0", "tier_1", "tier_2"]}
            }
          }
        }
      }
    },
    "attachment_handling": {
      "type": "object",
      "properties": {
        "mode": {"type": "string", "enum": ["strict", "permissive", "disabled"]},
        "require_user_approval": {"type": "array", "items": {"type": "string"}},
        "auto_allow": {"type": "array", "items": {"type": "string"}},
        "scanning": {
          "type": "object",
          "properties": {
            "detect_instructions": {"type": "boolean"},
            "action_on_detection": {"type": "string", "enum": ["block_and_flag", "warn", "log_only"]}
          }
        },
        "sandboxing": {
          "type": "object",
          "properties": {
            "wrap_content": {"type": "boolean"}
          }
        }
      }
    },
    "policies": {
      "type": "object",
      "required": ["cost_limits"],
      "properties": {
        "cost_limits": {
          "type": "object",
          "properties": {
            "per_request": {"type": "number", "minimum": 0},
            "daily": {"type": "number", "minimum": 0},
            "monthly": {"type": "number", "minimum": 0},
            "degradation": {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean"},
                "threshold_percent": {"type": "number", "minimum": 0, "maximum": 100},
                "fallback_model": {"type": "string"},
                "notify": {"type": "boolean"}
              }
            },
            "budget_alert_webhook": {"type": "string", "format": "uri"}
          }
        },
        "resource_limits": {
          "type": "object",
          "properties": {
            "cpu": {"type": "string"},
            "memory": {"type": "string"},
            "ephemeral_storage": {"type": "string"},
            "max_iterations": {"type": "integer", "minimum": 0, "maximum": 50},
            "max_tool_calls_per_run": {"type": "integer", "minimum": 0},
            "max_cost_per_run": {"type": "number", "minimum": 0},
            "max_retries_per_node": {"type": "integer", "minimum": 0},
            "require_approval": {"type": "array", "items": {"type": "string"}},
            "timeout": {
              "type": "object",
              "properties": {
                "operation": {"type": "string"},
                "tool_execution": {"type": "string"},
                "agent_total": {"type": "string"}
              }
            }
          }
        },
        "rate_limits": {
          "type": "object",
          "properties": {
            "requests_per_minute": {"type": "integer", "minimum": 1},
            "concurrent_executions": {"type": "integer", "minimum": 1},
            "per_agent_requests_per_minute": {"type": "integer", "minimum": 1},
            "circuit_breaker_threshold": {"type": "integer", "minimum": 1},
            "circuit_breaker_window": {"type": "string"},
            "tool_failure_threshold": {"type": "integer", "minimum": 1},
            "tool_failure_window": {"type": "string"}
          }
        },
        "session_limits": {
          "type": "object",
          "properties": {
            "max_cost": {"type": "number", "minimum": 0},
            "max_candidates": {"type": "integer", "minimum": 0},
            "max_judge_calls": {"type": "integer", "minimum": 0}
          }
        },
        "data_classification": {
          "type": "object",
          "properties": {
            "input_scan": {"type": "boolean"},
            "output_scan": {"type": "boolean"},
            "redact_pii": {"type": "boolean"},
            "redact_input": {"type": "boolean"},
            "redact_output": {"type": "boolean"},
            "block_on_pii": {"type": "boolean"},
            "max_data_tier": {"$ref": "#/definitions/dataTier"},
            "enabled_entities": {"type": "array", "items": {"type": "string"}},
            "disabled_entities": {"type": "array", "items": {"type": "string"}},
            "custom_recognizers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "supported_entity"],
                "additionalProperties": false,
                "properties": {
                  "name": {"type": "string"},
                  "supported_entity": {"type": "string"},
                  "sensitivity": {"type": "integer", "minimum": 1, "maximum": 3},
                  "patterns": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["name", "regex"],
                      "additionalProperties": false,
                      "properties": {
                        "name": {"type": "string"},
                        "regex": {"type": "string"},
                        "score": {"type": "number", "minimum": 0, "maximum": 1}
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "semantic_enrichment": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "mode": {"type": "string", "enum": ["off", "shadow", "enforce"]},
            "confidence_threshold": {"type": "number", "minimum": 0, "maximum": 1},
            "emit_unknown_attributes": {"type": "boolean"},
            "default_person_gender": {"type": "string"},
            "default_location_scope": {"type": "string"},
            "preserve_titles": {"type": "boolean"},
            "locale_hint_source": {"type": "string"},
            "allowed_attributes": {"type": "array", "items": {"type": "string"}}
          }
        },
        "model_routing": {
          "type": "object",
          "properties": {
            "tier_0": {"$ref": "#/definitions/modelRoutingTier"},
            "tier_1": {"$ref": "#/definitions/modelRoutingTier"},
            "tier_2": {"$ref": "#/definitions/modelRoutingTier"}
          }
        },
        "time_restrictions": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "allowed_hours": {"type": "string"},
            "timezone": {"type": "string"},
            "weekends": {"type": "boolean"}
          }
        },
        "models": {
          "type": "object",
          "description": "Flat model allow/block lists for this agent's gateway traffic. Distinct from model_routing (runner-side tier routing preference): models decides what MAY be called, model_routing what the runner PREFERS.",
          "additionalProperties": false,
          "properties": {
            "allowed": {
              "type": "array",
              "items": {"type": "string", "not": {"const": "*"}},
              "description": "Allow list; matched literally, so \"*\" is rejected (it would deny every model). Empty = unrestricted."
            },
            "blocked": {"type": "array", "items": {"type": "string"}}
          }
        },
        "allowed_providers": {
          "type": "array",
          "items": {"type": "string", "not": {"const": "*"}},
          "description": "Gateway providers this agent may reach; matched literally, so \"*\" is rejected (it would deny every provider). Empty = all enabled providers."
        },
        "egress": {
          "type": "object",
          "description": "A second egress boundary evaluated ALONGSIDE the organization policy: a destination must be permitted by BOTH (logical intersection). The agent can only narrow within the organization boundary, never widen or replace it.",
          "additionalProperties": false,
          "properties": {
            "default_action": {"type": "string", "enum": ["allow", "deny"]},
            "rules": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["tier"],
                "additionalProperties": false,
                "properties": {
                  "tier": {"$ref": "#/definitions/dataTier"},
                  "allowed_providers": {"type": "array", "items": {"type": "string"}},
                  "allowed_regions": {"type": "array", "items": {"type": "string"}}
                }
              }
            }
          }
        }
      }
    },
    "tool_policies": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "arguments": {
            "type": "object",
            "additionalProperties": {"type": "string", "enum": ["allow", "redact", "audit", "block"]}
          },
          "argument_default": {"type": "string", "enum": ["allow", "redact", "audit", "block"]},
          "result": {"type": "string", "enum": ["allow", "redact", "audit", "block"]},
          "timeout": {"type": "string"},
          "max_row_count": {"type": "integer", "minimum": 0},
          "require_dry_run": {"type": "boolean"},
          "dry_run_threshold": {"type": "integer", "minimum": 0},
          "forbidden_argument_values": {
            "type": "object",
            "additionalProperties": {"type": "array", "items": {"type": "string"}}
          },
          "schema_validation": {"type": "string", "enum": ["enforce", "shadow", "disabled"]}
        }
      }
    },
    "tool_governance": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "idempotency_key": {"type": "string"},
          "cache_ttl": {"type": "string"},
          "on_duplicate": {"type": "string", "enum": ["return_cached", "fail"]},
          "strict_mode": {"type": "boolean"}
        }
      }
    },
    "audit": {
      "type": "object",
      "properties": {
        "log_level": {"type": "string", "enum": ["minimal", "detailed", "full"]},
        "retention_days": {"type": "integer", "minimum": 1},
        "include_prompts": {"type": "boolean"},
        "include_responses": {"type": "boolean"},
        "observation_only": {"type": "boolean"},
        "include_original_prompts": {"type": "boolean"}
      }
    },
    "compliance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "frameworks": {"type": "array", "items": {"type": "string"}},
        "data_residency": {"type": "string"},
        "ai_act_risk_level": {"type": "string", "enum": ["minimal", "limited", "high"]},
        "human_oversight": {"type": "string", "enum": ["none", "on-demand", "always"]},
        "declarations": {
          "type": "object",
          "description": "Per-agent declared facts used to populate auditor exports (GDPR Art. 30 RoPA, EU AI Act Annex IV). Declared facts only — runtime facts come from the signed evidence store. Missing declarations produce flagged placeholders in exports, never failures.",
          "properties": {
            "processing": {
              "type": "object",
              "description": "GDPR Art. 30(1) processing-record declarations.",
              "properties": {
                "purposes": {"type": "array", "items": {"type": "string"}, "description": "Purposes of processing (Art. 30(1)(b))."},
                "data_subject_categories": {"type": "array", "items": {"type": "string"}, "description": "Categories of data subjects (Art. 30(1)(c)), e.g. customers, employees."},
                "personal_data_categories": {"type": "array", "items": {"type": "string"}, "description": "Declared personal-data categories; merged with PII entity types observed in evidence."},
                "retention_period": {"type": "string", "description": "Envisaged erasure time limit (Art. 30(1)(f)), e.g. \"90 days\"."},
                "safeguards": {"type": "string", "description": "Organisational measures beyond Talon's technical controls (Art. 30(1)(g))."},
                "legal_basis": {"type": "string", "description": "Lawful basis relied upon (Art. 6), e.g. contract, legitimate interest."}
              }
            },
            "system": {
              "type": "object",
              "description": "EU AI Act Annex IV technical-documentation declarations.",
              "properties": {
                "system_description": {"type": "string", "description": "General description of the AI system and its role (Annex IV s.1)."},
                "intended_purpose": {"type": "string", "description": "What the system is intended to be used for."},
                "oversight_description": {"type": "string", "description": "Human-oversight arrangements beyond Talon's plan-review/approval gates (Art. 14)."}
              }
            }
          }
        },
        "plan_review": {
          "type": "object",
          "properties": {
            "require_for_tools": {"type": "boolean"},
            "require_for_tier": {"type": "string", "enum": ["tier_0", "tier_1", "tier_2"]},
            "cost_threshold": {"type": "number", "minimum": 0},
            "timeout_minutes": {"type": "integer", "minimum": 0},
            "notify_webhook": {"type": "string"},
            "volume_threshold": {"type": "integer", "minimum": 0},
            "mode": {"type": "string", "enum": ["sequential", "any"]},
            "approval_chain": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["role"],
                "properties": {
                  "role": {"type": "string"},
                  "timeout_minutes": {"type": "integer", "minimum": 0},
                  "escalate_on_timeout": {"type": "boolean"}
                }
              }
            }
          }
        }
      }
    },
    "copaw": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "object",
          "properties": {
            "web_search": {"type": "string", "enum": ["allow", "deny"]},
            "file_read": {"type": "string", "enum": ["allow", "deny"]},
            "file_write": {"type": "string", "enum": ["allow", "deny", "deny_sensitive_paths"]},
            "external_api": {
              "type": "object",
              "properties": {
                "allowlist": {"type": "array", "items": {"type": "string"}}
              }
            },
            "digest_send": {
              "type": "object",
              "properties": {
                "pii_scan": {"type": "boolean"},
                "require_approval": {"type": "string", "enum": ["tier_1", "tier_2", "none"]}
              }
            }
          }
        },
        "memory": {
          "type": "object",
          "properties": {
            "forbidden_phrases": {"type": "array", "items": {"type": "string"}}
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "team": {"type": "string", "description": "Team this agent's spend and evidence attribute to (cost-by-team reporting)."},
        "department": {"type": "string"},
        "owner": {"type": "string"},
        "created_at": {"type": "string"},
        "tags": {"type": "array", "items": {"type": "string"}}
      }
    }
  },
  "definitions": {
    "dataTier": {
      "description": "Data classification tier: 0/public, 1/internal, 2/confidential (number or named alias).",
      "oneOf": [
        {"type": "integer", "minimum": 0, "maximum": 2},
        {"type": "string", "enum": ["public", "internal", "confidential"]}
      ]
    },
    "modelRoutingTier": {
      "type": "object",
      "description": "Per-tier model routing. `location` is declarative documentation only; region enforcement comes from provider registry metadata + llm.routing.data_sovereignty_mode.",
      "properties": {
        "primary": {"type": "string"},
        "fallback": {"type": "string"},
        "fallback_chain": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Ordered error-driven fallback chain: on a transient provider failure (timeout/connection/429/5xx) the runner retries these models in order, subject to the same compliance/sovereignty routing checks as the primary. Supersedes the single `fallback` for error-driven failover."
        },
        "location": {"type": "string"},
        "bedrock_only": {"type": "boolean"}
      }
    }
  }
}
