{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/dativo-io/talon/schemas/talon.config.schema.json",
  "title": "Talon Infrastructure Config",
  "description": "JSON Schema for talon.config.yaml — infrastructure configuration owned by the DevOps/platform team. Covers LLM provider connections, gateway settings, storage paths, semantic cache, and observability. Agent policy (capabilities, compliance, cost limits) belongs in agent.talon.yaml.",
  "type": "object",
  "definitions": {
    "dataTier": {
      "oneOf": [
        { "type": "integer", "minimum": 0, "maximum": 2 },
        { "type": "string", "enum": ["public", "internal", "confidential"] }
      ],
      "description": "Data classification tier: 0/public, 1/internal, 2/confidential (ascending sensitivity). String aliases are matched case-insensitively by Talon; this schema lists the lowercase canonical form."
    },
    "piiAction": {
      "type": "string",
      "enum": ["allow", "warn", "redact", "block"]
    },
    "toolPolicyAction": {
      "type": "string",
      "enum": ["filter", "block"],
      "description": "filter (default) removes forbidden tools from the request; block rejects the request."
    },
    "attachmentPolicy": {
      "type": "object",
      "description": "Scanning of base64-encoded file attachments embedded in LLM API requests.",
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "enum": ["block", "strip", "warn", "allow"], "default": "warn" },
        "injection_action": { "type": "string", "enum": ["block", "strip", "warn"], "default": "warn" },
        "max_file_size_mb": { "type": "integer", "minimum": 1, "default": 10 },
        "allowed_types": { "type": "array", "items": { "type": "string" } },
        "blocked_types": { "type": "array", "items": { "type": "string" } }
      }
    },
    "gatewayEgressPolicy": {
      "type": "object",
      "description": "Egress allow/deny rules keyed on data classification tier and destination provider/region. Supports data-transfer controls; decisions are recorded in signed evidence.",
      "properties": {
        "default_action": {
          "type": "string",
          "enum": ["allow", "deny"],
          "default": "allow",
          "description": "Applied when no rule covers the request's data tier."
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tier"],
            "properties": {
              "tier": { "$ref": "#/definitions/dataTier" },
              "allowed_providers": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Destination provider names; \"*\" matches any configured provider."
              },
              "allowed_regions": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Destination regions (e.g. EU, US, LOCAL) matched against the provider's resolved region. An unknown region never matches (fail-closed)."
              }
            }
          }
        }
      }
    }
  },
  "properties": {
    "data_dir": {
      "type": "string",
      "description": "Base directory for all state (evidence.db, secrets.db, cache.db, agent state). Default ~/.talon. Env: TALON_DATA_DIR."
    },
    "secrets_key": {
      "type": "string",
      "description": "AES-256 vault encryption key (exactly 32 bytes). Prefer the TALON_SECRETS_KEY env var over putting key material in this file."
    },
    "signing_key": {
      "type": "string",
      "description": "HMAC-SHA256 evidence signing key (>= 32 bytes). Prefer the TALON_SIGNING_KEY env var over putting key material in this file."
    },
    "default_policy": {
      "type": "string",
      "default": "agent.talon.yaml",
      "description": "Filename of the agent policy file loaded by default."
    },
    "max_attachment_mb": {
      "type": "integer",
      "minimum": 1,
      "default": 10,
      "description": "Maximum attachment size in MB for agent runs."
    },
    "ollama_base_url": {
      "type": "string",
      "format": "uri",
      "default": "http://localhost:11434",
      "description": "Ollama API endpoint (operator infrastructure)."
    },
    "log_level": {
      "type": "string",
      "enum": ["debug", "info", "warn", "error"],
      "default": "info",
      "description": "Log level. The --log-level flag takes precedence over this value."
    },
    "log_format": {
      "type": "string",
      "enum": ["console", "json"],
      "default": "console",
      "description": "Log format. The --log-format flag takes precedence over this value."
    },
    "compliance": {
      "type": "object",
      "description": "Org-level declared facts used to populate auditor exports (GDPR Art. 30 RoPA, EU AI Act Annex IV). Owned by the platform team together with the DPO. Declared facts only — runtime facts come from the signed evidence store.",
      "properties": {
        "controller": {
          "type": "object",
          "description": "Data-controller identity for GDPR Art. 30(1)(a).",
          "properties": {
            "name": { "type": "string", "description": "Legal name of the controller organization." },
            "contact": { "type": "string", "description": "General contact point (email or address)." },
            "dpo_contact": { "type": "string", "description": "Data Protection Officer contact, where designated." },
            "address": { "type": "string", "description": "Registered address of the controller." },
            "representative": { "type": "string", "description": "EU representative, where applicable (GDPR Art. 27)." }
          }
        }
      }
    },
    "sovereignty": {
      "type": "object",
      "description": "Deployment sovereignty mode (air-gap presets and egress guard). Feature bet 5.3.",
      "properties": {
        "deployment_mode": {
          "type": "string",
          "enum": ["standard", "air_gap"],
          "default": "standard",
          "description": "air_gap enables eu_strict routing preset, EU/LOCAL egress defaults, and transport-level egress allowlist."
        },
        "allowed_egress_hosts": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional hosts/URLs added to the air-gap egress allowlist beyond ollama_base_url and gateway providers."
        }
      }
    },
    "cache": {
      "type": "object",
      "description": "Governed semantic cache (optional, off by default). Validated by `talon doctor`.",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "default_ttl": { "type": "integer", "minimum": 1, "default": 3600, "description": "Default entry TTL in seconds." },
        "ttl_by_tier": {
          "type": "object",
          "description": "Optional per-tier TTL overrides in seconds; falls back to default_ttl for tiers not listed.",
          "additionalProperties": false,
          "properties": {
            "public": { "type": "integer", "minimum": 1 },
            "internal": { "type": "integer", "minimum": 1 },
            "confidential": { "type": "integer", "minimum": 1 }
          }
        },
        "similarity_threshold": { "type": "number", "exclusiveMinimum": 0, "maximum": 1, "default": 0.92 },
        "max_entries_per_tenant": { "type": "integer", "minimum": 1, "default": 10000 }
      }
    },
    "llm": {
      "type": "object",
      "description": "LLM provider and routing configuration (provider registry, EU sovereignty).",
      "properties": {
        "providers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "description": "Provider type: openai, anthropic, ollama, bedrock, azure-openai, mistral, etc." },
              "config": { "type": "object", "description": "Provider-specific config (api_key, base_url, region)." },
              "enabled": { "type": "boolean", "default": true }
            }
          }
        },
        "routing": {
          "type": "object",
          "properties": {
            "data_sovereignty_mode": {
              "type": "string",
              "enum": ["eu_strict", "eu_preferred", "global"],
              "description": "EU data sovereignty: eu_strict (only EU/LOCAL), eu_preferred (prefer EU, allow fallback), global (no restriction)."
            }
          }
        },
        "pricing_file": {
          "type": "string",
          "default": "pricing/models.yaml",
          "description": "Path to the LLM pricing table (per-1M-token USD). Used for cost estimation in evidence and OTel."
        }
      }
    },
    "gateway": {
      "type": "object",
      "description": "LLM API Gateway configuration.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "listen_prefix": {
          "type": "string",
          "default": "/v1/proxy"
        },
        "mode": {
          "type": "string",
          "enum": ["enforce", "shadow", "log_only"],
          "default": "enforce",
          "description": "Runtime default when omitted is enforce. Generated starter configs set shadow explicitly for a safe rollout."
        },
        "trusted_proxy_cidrs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "X-Forwarded-For is trusted for client IP only when the direct peer is in one of these CIDRs. Empty = never trust X-Forwarded-For."
        },
        "dashboard_listen": {
          "type": "string",
          "description": "Optional separate bind address for the gateway dashboard (e.g. 127.0.0.1:9091). When empty, dashboard routes are served on the main API server."
        },
        "response_scanning": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false }
          },
          "description": "Scan LLM responses for PII."
        },
        "network_interception": {
          "type": "object",
          "description": "Enterprise DNS interception: route SDK traffic to the gateway without changing app code.",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "intercept_hosts": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["original", "provider"],
                "properties": {
                  "original": { "type": "string" },
                  "provider": { "type": "string" },
                  "note": { "type": "string" }
                }
              }
            },
            "tls": {
              "type": "object",
              "required": ["cert_dir"],
              "properties": {
                "cert_dir": { "type": "string" }
              }
            }
          }
        },
        "providers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "secret_name": { "type": "string" },
              "upstream_auth_mode": {
                "type": "string",
                "enum": ["secret", "client_bearer"],
                "default": "secret",
                "description": "secret reads provider credentials from Talon's vault; client_bearer forwards the caller bearer token upstream (quickstart proxy mode only)."
              },
              "base_url": { "type": "string", "format": "uri" },
              "region": {
                "type": "string",
                "description": "Jurisdiction of the upstream endpoint (e.g. EU, US, LOCAL). Used by egress rules and data-flow evidence; required for custom base_url providers when region-based egress rules apply."
              },
              "allowed_models": {
                "type": "array",
                "items": { "type": "string" }
              },
              "blocked_models": {
                "type": "array",
                "items": { "type": "string" }
              },
              "forbidden_tools": {
                "type": "array",
                "items": { "type": "string" }
              },
              "tool_policy_action": { "$ref": "#/definitions/toolPolicyAction" }
            }
          }
        },
        "callers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "tenant_key": { "type": "string", "description": "Bearer key the caller presents; default identification method." },
              "tenant_id": { "type": "string" },
              "team": { "type": "string" },
              "tags": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Free-form tags (e.g. copaw) for OTel/dashboard classification."
              },
              "allowed_providers": {
                "type": "array",
                "items": { "type": "string" }
              },
              "identify_by": {
                "type": "string",
                "enum": ["source_ip"],
                "description": "Set to source_ip for IP-based caller identification (requires source_ip_ranges). Omit for bearer tenant_key auth (default)."
              },
              "source_ip_ranges": {
                "type": "array",
                "items": { "type": "string" }
              },
              "policy_overrides": {
                "type": "object",
                "properties": {
                  "max_daily_cost": { "type": "number", "minimum": 0 },
                  "max_monthly_cost": { "type": "number", "minimum": 0 },
                  "pii_action": { "$ref": "#/definitions/piiAction" },
                  "response_pii_action": { "$ref": "#/definitions/piiAction" },
                  "allowed_models": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "blocked_models": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "max_data_tier": { "$ref": "#/definitions/dataTier" },
                  "attachment_policy": { "$ref": "#/definitions/attachmentPolicy" },
                  "allowed_tools": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "forbidden_tools": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "tool_policy_action": { "$ref": "#/definitions/toolPolicyAction" },
                  "egress": { "$ref": "#/definitions/gatewayEgressPolicy" }
                }
              }
            }
          }
        },
        "default_policy": {
          "type": "object",
          "properties": {
            "default_pii_action": { "$ref": "#/definitions/piiAction" },
            "response_pii_action": { "$ref": "#/definitions/piiAction" },
            "max_daily_cost": { "type": "number", "minimum": 0 },
            "max_monthly_cost": { "type": "number", "minimum": 0 },
            "require_caller_id": { "type": "boolean", "default": true },
            "log_prompts": { "type": "boolean" },
            "log_responses": { "type": "boolean" },
            "log_response_preview_chars": { "type": "integer", "minimum": 0 },
            "attachment_policy": { "$ref": "#/definitions/attachmentPolicy" },
            "forbidden_tools": {
              "type": "array",
              "items": { "type": "string" }
            },
            "tool_policy_action": { "$ref": "#/definitions/toolPolicyAction" },
            "egress": { "$ref": "#/definitions/gatewayEgressPolicy" }
          }
        },
        "rate_limits": {
          "type": "object",
          "properties": {
            "global_requests_per_min": { "type": "integer", "minimum": 1 },
            "per_caller_requests_per_min": { "type": "integer", "minimum": 1 }
          }
        },
        "timeouts": {
          "type": "object",
          "properties": {
            "connect_timeout": { "type": "string" },
            "request_timeout": { "type": "string" },
            "stream_idle_timeout": { "type": "string" }
          }
        }
      }
    }
  }
}
