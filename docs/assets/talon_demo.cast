[0.03846, "o", "\u001b[?2004h\u001b]0;openclaw@ubuntu-s-2vcpu-4gb-ams3-01: ~/talon/examples/governed-session\u0007\u001b[01;32mopenclaw@ubuntu-s-2vcpu-4gb-ams3-01\u001b[00m:\u001b[01;34m~/talon/examples/governed-session\u001b[00m$ "]
